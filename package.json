{
  "name": "oefa-stateful-scraper",
  "version": "1.0.0",
  "private": true,
  "description": "Stateful TypeScript/Node.js scraper for the OEFA JSF repository.",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "demo": "ts-node src/index.ts --max-pages=2",
    "retry-failed": "ts-node src/index.ts --mode=retry",
    "build": "tsc --noEmit",
    "test": "node --test tests"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "tough-cookie": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
